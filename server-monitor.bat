@echo off
chcp 65001 >nul
setlocal enabledelayedexpansion

set "SCRIPT_PATH=%~f0"
set "SCRIPT_DIR=%~dp0"
set "EXTRACT_DIR=%SCRIPT_DIR%server-monitor"
set "UV_DIR=%USERPROFILE%\.local\bin"
set "PATH=%UV_DIR%;%PATH%"

echo [server-monitor] Checking uv...

where uv >nul 2>&1
if %errorlevel% neq 0 (
    if exist "%UV_DIR%\uv.exe" (
        set "PATH=%UV_DIR%;%PATH%"
    ) else (
        echo [server-monitor] uv not found. Installing uv...
        powershell -NoProfile -ExecutionPolicy Bypass -Command "irm https://astral.sh/uv/install.ps1 | iex"
        if !errorlevel! neq 0 (
            echo [server-monitor] ERROR: Failed to install uv.
            pause
            exit /b 1
        )
        set "PATH=%UV_DIR%;%PATH%"
    )
)

echo [server-monitor] Installing Python via uv...
uv python install 3.11
if !errorlevel! neq 0 (
    echo [server-monitor] ERROR: Failed to install Python.
    pause
    exit /b 1
)

echo [server-monitor] Extracting archive...
if exist "%EXTRACT_DIR%" rmdir /s /q "%EXTRACT_DIR%" 2>nul
if exist "%EXTRACT_DIR%" (
    set "OLD_DIR=%EXTRACT_DIR%.old.%RANDOM%"
    ren "%EXTRACT_DIR%" "!OLD_DIR!" 2>nul
)

powershell -NoProfile -ExecutionPolicy Bypass -Command "$lines = Get-Content $env:SCRIPT_PATH; $idx = -1; for ($i = 0; $i -lt $lines.Count; $i++) { if ($lines[$i] -eq '__ARCHIVE_BELOW__') { $idx = $i; break } }; if ($idx -lt 0) { throw 'Archive marker not found' }; $base64 = ($lines | Select-Object -Skip ($idx + 1)) -join ''; $tar = Join-Path $env:TEMP 'server-monitor.tar.gz'; [System.IO.File]::WriteAllBytes($tar, [Convert]::FromBase64String($base64)); New-Item -ItemType Directory -Force -Path $env:EXTRACT_DIR | Out-Null; tar -xzf $tar -C $env:EXTRACT_DIR"
if !errorlevel! neq 0 (
    echo [server-monitor] ERROR: Extraction failed.
    pause
    exit /b 1
)

echo [server-monitor] Extracted to: %EXTRACT_DIR%

cd /d "%EXTRACT_DIR%"

echo [server-monitor] Creating virtual environment...
uv venv --clear
if !errorlevel! neq 0 (
    echo [server-monitor] ERROR: Failed to create venv.
    pause
    exit /b 1
)

echo [server-monitor] Installing dependencies...
uv pip install -r requirements.txt

echo [server-monitor] Setting up auto-start (Task Scheduler)...
schtasks /create /tn "ServerMonitor" /tr "\"%EXTRACT_DIR%\.venv\Scripts\python.exe\" app.py" /sc onlogon /rl highest /f >nul 2>&1
if !errorlevel! eq 0 (
    echo [server-monitor] Auto-start enabled. Task: ServerMonitor
    echo [server-monitor] Manage: schtasks /query /tn ServerMonitor ^| schtasks /delete /tn ServerMonitor
) else (
    echo [server-monitor] Auto-start setup skipped (need admin).
)

echo [server-monitor] Starting server at http://0.0.0.0:5000
".venv\Scripts\python.exe" app.py

pause

__ARCHIVE_BELOW__
